local HttpService = game:GetService("HttpService")

local placeId = game.PlaceId
local folder = workspace:FindFirstChild("StandArrow") or workspace

-- ✅ AUTO ON
getgenv().AutoFarm = true

--// ===== AUTO CLICK PLAY =====
local function autoClickPlay()
    local x = 960
    local y = 600

    local duration = 20
    local interval = 0.1

    local startTime = tick()

    while tick() - startTime < duration do
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
        task.wait(interval)
    end
end

task.spawn(function()
    task.wait(1.5)
    autoClickPlay()
end)

--// ===== FUNCTIONS =====

local function getPosition(obj)
    if obj:IsA("BasePart") then
        return obj.Position
    elseif obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.Position
        else
            local part = obj:FindFirstChildWhichIsA("BasePart")
            if part then
                return part.Position
            end
        end
    end
end

local function teleportTo(obj)
    local pos = getPosition(obj)
    if pos then
        root.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
    end
end

local function holdE(time)
    vim:SendKeyEvent(true, "E", false, game)
    task.wait(time)
    vim:SendKeyEvent(false, "E", false, game)
end

local function isPlayerNear(pos, radius)
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (plr.Character.HumanoidRootPart.Position - pos).Magnitude
            if dist <= radius then
                return true
            end
        end
    end
    return false
end

--// ===== SERVER HOP =====

local function serverHop()
    -- queue script before teleport
    if queue_on_teleport then
        queue_on_teleport('loadstring(game:HttpGet("' .. SCRIPT_URL .. '"))()')
    end

    local success, result = pcall(function()
        local req = game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100")
        return HttpService:JSONDecode(req)
    end)

    if success and result and result.data then
        local servers = {}

        for _, v in pairs(result.data) do
            if v.playing < v.maxPlayers then
                table.insert(servers, v.id)
            end
        end

        if #servers > 0 then
            local randomServer = servers[math.random(1, #servers)]
            TeleportService:TeleportToPlaceInstance(placeId, randomServer, player)
        else
            TeleportService:Teleport(placeId, player)
        end
    else
        TeleportService:Teleport(placeId, player)
    end
end

--// ===== AUTOFARM LOOP =====

local noArrowTime = 0
local HOP_DELAY = 5

task.spawn(function()
    while true do
        if getgenv().AutoFarm then
            local foundValidArrow = false

            for _, v in pairs(folder:GetDescendants()) do
                if string.find(v.Name:lower(), "arrow") then
                    local pos = getPosition(v)

                    if pos and not isPlayerNear(pos, 12) then
                        foundValidArrow = true
                        noArrowTime = 0

                        teleportTo(v)
                        task.wait(0.2)

                        holdE(0.5)

                        task.wait(0.2)
                    end
                end
            end

            if not foundValidArrow then
                noArrowTime += 1
                if noArrowTime >= HOP_DELAY then
                    serverHop()
                end
            end
        end

        task.wait(1)
    end
end)

